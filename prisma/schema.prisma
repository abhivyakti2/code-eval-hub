//This is a configuration file 

generator client {
  provider = "prisma-client-js"
}
// generator → a keyword in Prisma (tells Prisma to generate something), using npx prisma generate
// client → just a name you give to this generator (you could technically name it anything)
// provider = "prisma-client-js" → specifies what to generate (here, the Prisma Client for JS/TS : node_modules/@prisma/client)
//Prisma Client = a JS library with functions like prisma.user.findMany() to query DB

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
// This is my database, here’s its type and how to connect to it.

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  chats     Chat[]
  createdAt DateTime @default(now())
}
// @id - primary key, cuid - generates unique string ID

model Repository {
  id                 String              @id @default(cuid())
  githubId           Int                 @unique
  githubUrl          String
  owner              String
  name               String
  description        String?
  language           String?
  lastCommitSha      String?
  //should be last ingested sha for clarity
  repoFaissUri       String?
  //where embedding is stored?
  createdAt          DateTime            @default(now())
  contributors       Contributor[]
  chats              Chat[]
  generatedQuestions GeneratedQuestion[]
  // TODO : per contributor there will be questions, is it accomodating that?
}
// TODO : can't id be githubId?
// ? because we get that from the api, and we don't know response will come or not

model Contributor {
  id                 String              @id @default(cuid())
  repositoryId       String
  githubLogin        String
  avatarUrl          String?
  totalCommits       Int                 @default(0)
  summary            String?
  faissUri           String?
  generatedQuestions GeneratedQuestion[]
  createdAt          DateTime            @default(now())
  repository         Repository          @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([repositoryId, githubLogin])
  @@index([repositoryId])
} 
//total commits can actually be 0 if added as contributor but didn't make any commits
// double @ → composite unique constraint. Individually they can repeat, but together they must be unique
//avatar idts needed, 
//CHAT -> REPO -> CONTRIBUTOR, but chat n contributor both are linked to questions...

enum MessageFeature {
  repo_summary
  contributors_summary
  generate_questions
  repo_chat
}
//can make repo chat a follow up option. questions should also be repo, contributor - 2 types

model Chat {
  id                 String              @id @default(cuid())
  userId             String
  repositoryId       String
  commitSha          String?
  // title        String     @default("New Chat"), put repo name w/ owner
  createdAt          DateTime            @default(now())
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  repository         Repository          @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  messages           Message[]
  generatedQuestions GeneratedQuestion[]
  //only here because linked to questions right?
  @@unique([userId, repositoryId])
  @@index([repositoryId])
}// TODO : shouldn't it be indexed based on user? same repo will not have more than 1 chat 
// w/ a user, but different users have chats with same repo, will be easier to display 
// single user's repos in history if indexed by user no?
// Makes queries like findMany({ where: { repositoryId } }) faster, but we'd want user's repos i think
// TODO : generate questions shouldn't be stored i think, they can be in message right since we don't need universal stored summary type stuff? there shouldn't be a generated message table 

enum MessageRole {
  user
  assistant
}

// TODO : keep a follow up link to previous question if the user isn't specifying the feature, 
// but for 1st message in chat, what to do? can check if chat has no msg, follow up disabled
model Message {
  id        String           @id @default(cuid())
  chatId    String
  role      MessageRole
  content   String
  features  MessageFeature[] @default([])
  createdAt DateTime         @default(now())
  chat      Chat             @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
}//TODO : but assistant message won't have message feature

//idts scope needed? feature should mention repo or contributor
enum QuestionScope {
  contributor
  repository
}

model GeneratedQuestion {
  id            String        @id @default(cuid())
  contributorId String?
  repositoryId  String
  chatId        String
  scope         QuestionScope
  questions     Json
  createdAt     DateTime      @default(now())
  contributor   Contributor?  @relation(fields: [contributorId], references: [id], onDelete: Cascade)
  repository    Repository    @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  chat          Chat          @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([repositoryId])
}
//why contributorId string? won't it be necessary to generate the questions?
// index should be based on chatid no? 
// TODO : ig contributors can be linked to chat too? maybe repo need not be linked to questions?